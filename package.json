{
  "name": "pi-zai-coding-plan",
  "version": "0.1.0",
  "description": "Pi extension that overrides the built-in zai provider with the Z.AI Coding Plan endpoint, models, thinking/reasoning mapping, and payload normalization.",
  "keywords": ["pi-package", "pi-extension", "zai", "glm", "coding-plan"],
  "license": "MIT",
  "type": "module",
  "main": "./extensions/zai-coding-plan.ts",
  "pi": {
    "extensions": ["./extensions"]
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "node --test"
  },
  "peerDependencies": {
    "@earendil-works/pi-agent-core": "*",
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "peerDependenciesMeta": {
    "@earendil-works/pi-agent-core": { "optional": true },
    "@earendil-works/pi-ai": { "optional": true },
    "@earendil-works/pi-coding-agent": { "optional": true },
    "@earendil-works/pi-tui": { "optional": true },
    "typebox": { "optional": true }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.6.0"
  }
}
